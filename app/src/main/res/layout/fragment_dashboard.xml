<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/navy_primary"
    android:orientation="vertical">

    <!-- Top Header -->
    <include layout="@layout/layout_top_header" />

    <!-- Content Area with rounded top -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_rounded_top"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- ===== SECTION 1: Profile Summary Card ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Student Avatar -->
                    <ImageView
                        android:id="@+id/img_student_avatar"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circle_avatar"
                        android:contentDescription="Student Photo"
                        android:padding="2dp"
                        android:src="@drawable/ic_attendance"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Student Name -->
                    <TextView
                        android:id="@+id/tv_student_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Aditya Sharma"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/img_student_avatar"
                        app:layout_constraintTop_toTopOf="@id/img_student_avatar" />

                    <!-- Active Badge -->
                    <TextView
                        android:id="@+id/badge_active"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_active_badge"
                        android:paddingStart="10dp"
                        android:paddingTop="2dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="2dp"
                        android:text="Active"
                        android:textColor="@color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/tv_student_name"
                        app:layout_constraintStart_toEndOf="@id/tv_student_name"
                        app:layout_constraintTop_toTopOf="@id/tv_student_name" />

                    <!-- View Profile Link -->
                    <TextView
                        android:id="@+id/tv_view_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="View Profile >"
                        android:textColor="@color/blue_accent"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Father's Name -->
                    <TextView
                        android:id="@+id/tv_father_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="6dp"
                        android:text="Father's Name"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toEndOf="@id/img_student_avatar"
                        app:layout_constraintTop_toBottomOf="@id/tv_student_name" />

                    <TextView
                        android:id="@+id/tv_father_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Vikram Sharma"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_father_label"
                        app:layout_constraintStart_toEndOf="@id/tv_father_label" />

                    <!-- Mother's Name -->
                    <TextView
                        android:id="@+id/tv_mother_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="4dp"
                        android:text="Mother's Name"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        app:layout_constraintStart_toEndOf="@id/img_student_avatar"
                        app:layout_constraintTop_toBottomOf="@id/tv_father_label" />

                    <TextView
                        android:id="@+id/tv_mother_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Neha Sharma"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintBaseline_toBaselineOf="@id/tv_mother_label"
                        app:layout_constraintStart_toEndOf="@id/tv_mother_label" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== SECTION 2: Performance Metrics (4 Columns) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card_rounded"
                android:elevation="2dp"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- Attendance -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attendance"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                    <com.studentprofile.app.views.CircularProgressView
                        android:id="@+id/progress_attendance"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginTop="8dp"
                        app:cpv_progress="88.5"
                        app:cpv_maxProgress="100"
                        app:cpv_progressColor="@color/progress_attendance"
                        app:cpv_trackColor="@color/progress_track"
                        app:cpv_strokeWidth="5dp"
                        app:cpv_showPercentage="true"
                        app:cpv_centerTextSize="13sp"
                        app:cpv_centerTextColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tv_attendance_present"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Present :  115"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_attendance_absent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Absent :  15"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Average Score -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Average Score"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                    <com.studentprofile.app.views.CircularProgressView
                        android:id="@+id/progress_avg_score"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginTop="8dp"
                        app:cpv_progress="78.6"
                        app:cpv_maxProgress="100"
                        app:cpv_progressColor="@color/progress_avg_score"
                        app:cpv_trackColor="@color/progress_track"
                        app:cpv_strokeWidth="5dp"
                        app:cpv_showPercentage="true"
                        app:cpv_centerTextSize="13sp"
                        app:cpv_centerTextColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tv_avg_grade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Grade:   B+"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_avg_rank"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rank:   8 / 42"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Homework Submitted -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Homework\nSubmitted"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                    <com.studentprofile.app.views.CircularProgressView
                        android:id="@+id/progress_homework"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginTop="8dp"
                        app:cpv_progress="92.3"
                        app:cpv_maxProgress="100"
                        app:cpv_progressColor="@color/progress_homework"
                        app:cpv_trackColor="@color/progress_track"
                        app:cpv_strokeWidth="5dp"
                        app:cpv_showPercentage="true"
                        app:cpv_centerTextSize="13sp"
                        app:cpv_centerTextColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tv_homework_submitted"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Submitted:  24"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_homework_pending"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending :   2"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />
                </LinearLayout>

                <!-- Behaviour -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Behaviour"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp" />

                    <FrameLayout
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:contentDescription="Behaviour"
                            android:src="@drawable/ic_star_badge" />

                        <TextView
                            android:id="@+id/tv_behaviour_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal|bottom"
                            android:fontFamily="sans-serif-medium"
                            android:text="Good"
                            android:textColor="@color/green_success"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/tv_num_remarks"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="No. of Remarks: 1"
                        android:textColor="@color/text_secondary"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/tv_view_details"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="View Details >"
                        android:textColor="@color/blue_accent"
                        android:textSize="9sp" />
                </LinearLayout>

            </LinearLayout>

            <!-- ===== SECTION 3: Subject-wise Performance ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_subject_performance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Title Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="Subject-wise Performance (This Term)"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_subject_view_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="View All >"
                            android:textColor="@color/blue_accent"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Subject Performance List Container -->
                    <LinearLayout
                        android:id="@+id/container_subject_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== SECTION 4: Recent Assessments ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_recent_assessments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Title Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fontFamily="sans-serif-medium"
                            android:text="Recent Assessments"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_assessment_view_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="View All >"
                            android:textColor="@color/blue_accent"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Assessment List Container -->
                    <LinearLayout
                        android:id="@+id/container_assessment_list"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== SECTION 5: Quick Actions ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium"
                android:text="Quick Actions"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/container_quick_actions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

            <Button
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:text="Logout"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:backgroundTint="#E53935"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
