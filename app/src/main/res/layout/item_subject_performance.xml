<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Subject Icon -->
    <FrameLayout
        android:id="@+id/subject_icon_container"
        android:layout_width="40dp"
        android:layout_height="40dp">

        <ImageView
            android:id="@+id/img_subject_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="Subject" />
    </FrameLayout>

    <!-- Subject Name -->
    <TextView
        android:id="@+id/tv_subject_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:fontFamily="sans-serif-medium"
        android:textColor="#2D3748"
        android:textSize="13sp" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_subject"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="80dp"
        android:layout_height="8dp"
        android:layout_marginStart="8dp"
        android:max="100"
        android:progressDrawable="@drawable/bg_progress_track" />

    <!-- Percentage -->
    <TextView
        android:id="@+id/tv_percentage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#2D3748"
        android:textSize="12sp" />

    <!-- Grade Capsule -->
    <TextView
        android:id="@+id/tv_grade"
        android:layout_width="32dp"
        android:layout_height="28dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_grade_capsule"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:textColor="#002874"
        android:textSize="11sp"
        android:textStyle="bold" />

    <!-- Chevron -->
    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="4dp"
        android:contentDescription="More"
        android:src="@drawable/ic_chevron_right" />
</LinearLayout>
