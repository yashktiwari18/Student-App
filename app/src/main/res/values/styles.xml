<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text Styles -->
    <style name="TextHeading">
        <item name="android:textSize">@dimen/text_heading</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextTitle">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextSubtitle">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextBody">
        <item name="android:textSize">@dimen/text_body</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextCaption">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextLink">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/blue_accent</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Card Style -->
    <style name="CardStyle">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>

    <!-- Badge Styles -->
    <style name="BadgeCompleted">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/green_success</item>
        <item name="android:background">@drawable/bg_completed_badge</item>
        <item name="android:paddingStart">@dimen/badge_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/badge_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/badge_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/badge_padding_vertical</item>
    </style>

    <style name="BadgePending">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/amber_pending</item>
        <item name="android:background">@drawable/bg_pending_badge</item>
        <item name="android:paddingStart">@dimen/badge_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/badge_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/badge_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/badge_padding_vertical</item>
    </style>

    <!-- Button Style -->
    <style name="OutlinedButton">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textColor">@color/blue_accent</item>
        <item name="android:background">@drawable/bg_action_button</item>
        <item name="android:paddingStart">@dimen/button_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/button_padding_horizontal</item>
        <item name="android:paddingTop">@dimen/button_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/button_padding_vertical</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
